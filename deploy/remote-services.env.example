# This host only runs the training pipeline. Service owners run Retriever and
# the OpenAI-compatible judge/updater elsewhere.
MANAGE_RETRIEVER=false
MANAGE_JUDGE=false

DRZERO_RETRIEVER_URL=http://retriever.internal:8020/retrieve
DRZERO_META_BASE_URL=http://judge.internal:8000
DRZERO_META_MODEL=Qwen/Qwen3.6-35B-A3B
DRZERO_UPDATER_BASE_URL=http://judge.internal:8000
DRZERO_UPDATER_MODEL=Qwen/Qwen3.6-35B-A3B

# Optional: name of an environment variable containing the remote API key.
# Keep the actual secret outside this file if this profile is committed.
DRZERO_META_API_KEY_ENV=
DRZERO_UPDATER_API_KEY_ENV=

TRAIN_GPU_DEVICES=0,1,2,3,4,5
GENERATION_GPU_DEVICES=0,1,2,3,4,5
