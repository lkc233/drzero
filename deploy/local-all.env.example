# This host manages Retriever and Qwen judge/updater locally.
MANAGE_RETRIEVER=true
MANAGE_JUDGE=true

DRZERO_RETRIEVER_URL=http://127.0.0.1:8020/retrieve
DRZERO_META_BASE_URL=http://127.0.0.1:8000
DRZERO_META_MODEL=Qwen/Qwen3.6-35B-A3B
DRZERO_UPDATER_BASE_URL=http://127.0.0.1:8000
DRZERO_UPDATER_MODEL=Qwen/Qwen3.6-35B-A3B

RETRIEVER_GPU_DEVICES=0,1
RETRIEVER_TYPE=e5_flat
RETRIEVER_PORT=8020
FAISS_USE_GPU=1
JUDGE_GPU_DEVICES=0,1
JUDGE_PORT=8000
JUDGE_TP_SIZE=2

TRAIN_GPU_DEVICES=2,3,4,5,6,7
GENERATION_GPU_DEVICES=2,3,4,5,6,7
